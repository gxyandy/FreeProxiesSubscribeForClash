proxy-providers:
  AiAGENT-NET:
    type: http
    path: ./ProxySet/dtqy/ai_agent_net_f034f800f34e1dd57b6383c6c655a59f.yaml
    url: "http://blue2sea.com/clash/proxies/aiAgent/2143c2ec19da075e495552259ad4bade?ua=clash-verge/v2.5.1"
    interval: 300
    filter: ''
    health-check:
      enable: true
      url: http://gstatic.com
      interval: 120
  ALL-NET:
    type: http
    path: ./ProxySet/dtqy/dt_net_f034f800f34e1dd57b6383c6c655a59f.yaml
    url: "http://blue2sea.com/clash/proxies/2143c2ec19da075e495552259ad4bade?ua=clash-verge/v2.5.1"
    interval: 300
    filter: ''
    health-check:
      enable: true
      url: http://gstatic.com
      interval: 120


proxy-groups:

  - name: 天边外丨blue2sea.com
    type: select
    url: http://gstatic.com
    interval: 60
    proxies:
      - 自动选择(全部节点)
      - 自动选择(不含香港&台湾)
    use:
      - ALL-NET

  - name: 自动选择(全部节点)
    type: url-test
    url: http://gstatic.com
    interval: 30
    use:
        - ALL-NET

  - name: 自动选择(不含香港&台湾)
    type: url-test
    url: http://gstatic.com
    interval: 30
    use:
      - AiAGENT-NET

  - name: AiAgent
    type: fallback
    url: http://gstatic.com
    interval: 30
    proxies:
      - 天边外丨blue2sea.com
      - 自动选择(不含香港&台湾)

  - name: Out
    type: fallback
    url: http://gstatic.com
    interval: 30
    proxies:
      - 天边外丨blue2sea.com
      - 自动选择(全部节点)

  - name: PROXY
    type: fallback
    url: http://gstatic.com
    interval: 30
    proxies:
      - Out
  - name: 🔒 纯净独享丨流媒体解锁
    type: url-test
    url: http://gstatic.com
    interval: 30
    use:
      - ALL-NET
    filter: '(?!.*_31$)'

  - name: 天边外丨优选
    type: url-test
    url: http://gstatic.com
    interval: 10
    use:
      - ALL-NET
    filter: '(?!.*_31$)'

  - name: 🎬 超清多媒体丨大数据加速
    type: fallback
    url: http://gstatic.com
    interval: 15
    proxies:
      - 🔒 纯净独享丨流媒体解锁
      - 天边外丨优选

  - name: Youtube
    type: fallback
    url: http://gstatic.com
    interval: 15
    proxies:
      - 🎬 超清多媒体丨大数据加速

  - name: Netflix
    type: fallback
    url: http://gstatic.com
    interval: 15
    proxies:
      - 🎬 超清多媒体丨大数据加速

  - name: Telegram
    type: fallback
    url: http://gstatic.com
    interval: 30
    proxies:
      - Out

  - name: Apple
    type: fallback
    url: http://gstatic.com
    interval: 30
    proxies:
      - DIR
      - Out

  - name: DIR
    type: select
    proxies:
      - DIRECT



