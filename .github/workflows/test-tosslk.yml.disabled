name: Update toshare

on:
  schedule:
    - cron: "*/30 * * * *"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  update-toshare:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Fetch toshare5 subscription into toshare
        run: |
          python - <<'PY'
          import re
          import sys
          import urllib.request
          from pathlib import Path

          SOURCE_PAGE_URL = "https://github.com/toshare5/toshare5.github.io"
          OUTPUT_FILE = Path("toshare")

          PAGE_HEADERS = {
              "User-Agent": (
                  "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                  "AppleWebKit/537.36 (KHTML, like Gecko) "
                  "Chrome/125.0 Safari/537.36"
              ),
              "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
          }

          CLASH_HEADERS = {
              "User-Agent": "clash-verge/v2.5.1",
              "Accept": "*/*",
          }

          def fetch_bytes(url, headers):
              request = urllib.request.Request(url, headers=headers)
              with urllib.request.urlopen(request, timeout=30) as response:
                  return response.read(), response.headers.get_content_charset() or "utf-8"

          def fetch_text(url, headers):
              data, charset = fetch_bytes(url, headers)
              return data.decode(charset, errors="replace")

          page_text = fetch_text(SOURCE_PAGE_URL, PAGE_HEADERS)

          markers = [
              "\U0001f680免费Clash订阅链接",
              "免费Clash订阅链接",
          ]

          subscription_url = None
          for marker in markers:
              idx = page_text.find(marker)
              if idx != -1:
                  after = page_text[idx:idx + 2000]
                  m = re.search(r"(https?://[^\s<>\"'`\n]+)", after)
                  if m:
                      subscription_url = m.group(1).strip()
                      break

          if not subscription_url:
              print("没有找到‘免费Clash订阅链接’标记或其后的 URL", file=sys.stderr)
              sys.exit(1)

          print(f"提取到订阅地址：{subscription_url}")

          subscription_data, _ = fetch_bytes(subscription_url, CLASH_HEADERS)

          if not subscription_data.strip():
              print("订阅地址返回内容为空", file=sys.stderr)
              sys.exit(1)

          text_preview = subscription_data[:500].decode("utf-8", errors="ignore")

          is_base64_like = (
              re.match(r"^[A-Za-z0-9+/=\s]+$", text_preview)
              and len(subscription_data) > 100
              and "proxies:" not in text_preview
              and "mixed-port:" not in text_preview
          )

          if is_base64_like:
              print("订阅内容看起来像 Base64 编码，直接保存原始内容")
          else:
              print("订阅内容看起来像 YAML/文本，直接保存原始内容")

          OUTPUT_FILE.write_bytes(subscription_data.rstrip() + b"\n")
          print(f"已更新 {OUTPUT_FILE}")
          PY

      - name: Commit and push
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add toshare
          if git diff --cached --quiet; then
            echo "toshare 没有变化，不需要提交。"
          else
            git commit -m "Update toshare subscription"
            git push
          fi
